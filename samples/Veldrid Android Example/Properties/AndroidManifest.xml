<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <!-- Minimum API 24 (Android 7.0 Nougat) — required for Vulkan 1.0 support -->
  <uses-sdk android:minSdkVersion="24" android:targetSdkVersion="35" />

  <!-- Vulkan hardware feature (not required — allows fallback to OpenGL ES on devices without Vulkan) -->
  <uses-feature android:name="android.hardware.vulkan.level" android:version="0" android:required="false" />
  <uses-feature android:name="android.hardware.vulkan.version" android:version="0x00400000" android:required="false" />

  <!-- OpenGL ES 3.0 as fallback graphics capability -->
  <uses-feature android:glEsVersion="0x00030000" android:required="false" />

  <!-- Touchscreen required for touch→mouse mapping -->
  <uses-feature android:name="android.hardware.touchscreen" android:required="true" />

  <application
    android:allowBackup="true"
    android:label="SilkyNvg Veldrid Example"
    android:hardwareAccelerated="true"
    android:supportsRtl="true">
    <!-- Activity is generated from [Activity] attribute in MainActivity.cs -->
  </application>

</manifest>