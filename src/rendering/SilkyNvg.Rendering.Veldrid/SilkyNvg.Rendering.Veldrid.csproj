<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <!-- UseLegacyVeldrid is inherited from Directory.Build.props (workspace root or parent).
         Default (undefined): uses ppy.Veldrid — the actively maintained fork used by osu!
         Set UseLegacyVeldrid=true in your Directory.Build.props to use upstream Veldrid 4.9.0.
         If pulling SilkyNvg into a standalone project, ppy.Veldrid is used by default. -->
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SilkyNvg.Rendering\SilkyNvg.Rendering.csproj" />
    <ProjectReference Include="..\..\components\SilkyNvg.Blending\SilkyNvg.Blending.csproj" />
    <ProjectReference Include="..\..\components\SilkyNvg.Images\SilkyNvg.Images.csproj" />
    <ProjectReference Include="..\..\components\SilkyNvg.Tools\SilkyNvg.Tools.csproj" />
    
    <!-- Build shader compiler first to generate .generated.cs files before this project compiles -->
    <ProjectReference Include="Scripts\CompileShaders.csproj" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- ppy.Veldrid fork: actively maintained, Android/iOS support (default) -->
  <!-- Veldrid.SPIRV removed: shaders are precompiled at build time by Scripts/CompileShaders.cs -->
  <ItemGroup Condition="'$(UseLegacyVeldrid)' != 'true'">
    <PackageReference Include="ppy.Veldrid" Version="4.9.69-ga405fe8484" />
  </ItemGroup>

  <!-- Legacy upstream Veldrid 4.9.0 (abandoned March 2024, desktop-only) -->
  <ItemGroup Condition="'$(UseLegacyVeldrid)' == 'true'">
    <PackageReference Include="Veldrid" Version="4.9.0" />
  </ItemGroup>

  <!-- Exclude build-time scripts and GLSL source from compilation -->
  <ItemGroup>
    <Compile Remove="Scripts\**" />
    <None Include="Scripts\**" />
    <Compile Remove="Shaders\Source\**" />
    <None Include="Shaders\Source\**" />
  </ItemGroup>

  <!-- Explicitly include generated shader files so MSBuild always sees them -->
  <ItemGroup>
    <Compile Include="Shaders\Compiled\SolidFillShaders.generated.cs" />
    <Compile Include="Shaders\Compiled\TexturedShaders.generated.cs" />
    <Compile Include="Shaders\Compiled\GradientShaders.generated.cs" />
    <Compile Include="Shaders\Compiled\ImagePatternShaders.generated.cs" />
  </ItemGroup>

</Project>